[ext_resource type="FontFile" path="res://assets/keys/kenney_input_playstation_series.ttf" id="1_px1vu"]

[sub_resource type="GDScript" id="GDScript_5dnyf"]
script/source = "extends Node3D

func _ready() -> void:
	$Label2.text = \"\\uE059\"

func _input(event: InputEvent) -> void:
	if event is InputEventJoypadButton:
		$Label.text = get_gamepad_glyph(event.button_index)


func get_gamepad_glyph(button_index: int) -> String:
	var glyphs = {
		# === Face buttons ===
		0: \"\\uE049\",   # A / Cross
		1: \"\\uE03F\",   # B / Circle
		2: \"\\uE04F\",   # X / Square
		3: \"\\uE051\",   # Y / Triangle
		
		# === Shoulder triggers ===
		4: \"\\uE076\",   # Left Shoulder / L1
		5: \"\\uE07E\",   # Right Shoulder / R1
		6: \"\\uE04B\",   # Left Stick / L3
		7: \"\\uE04D\",   # Right Stick / R3
		
		# === System buttons ===
		8: \"\\uE009\",   # Start / Options
		9: \"\\uE00B\",   # Back / Share
		10: \"\\uE004\",  # Guide / PS Button (PS5 controller icon)
		
		# === D-Pad ===
		11: \"\\uE05E\",  # D-Pad Up
		12: \"\\uE01D\",  # D-Pad Down
		13: \"\\uE01F\",  # D-Pad Left
		14: \"\\uE021\",  # D-Pad Right
		
		# === Triggers L2/R2 (аналоговые, но показываем как кнопки) ===
		15: \"\\uE07A\",  # Left Trigger 2 / L2
		16: \"\\uE082\",  # Right Trigger 2 / R2
		
		# === Misc ===
		17: \"\\uE03D\",  # Analog stick generic
	}
	return glyphs.get(button_index, \"\\uE000\")  # fallback на generic controller
"

